# GPT-4o Vision è il provider principale per l'analisi documentale pubblica.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Gemini è facoltativo e viene usato solo come fallback controllato.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_FALLBACK_MODELS=gemini-2.0-flash
GEMINI_VISION_USE_SCHEMA=0

# Token richiesto per visualizzare /admin/evaluation?token=...
ADMIN_EVALUATION_TOKEN=

# Stripe Checkout Hosted per Screening AI da 0,99 €.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Modalita lancio gratuito. Se true, lo screening non richiede Checkout Stripe.
FREE_SCREENING_MODE=true

# Supabase persistence per pagamenti e report.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend per notifiche richieste consulenza.
RESEND_API_KEY=
CONSULTATION_TO_EMAIL=multeonlineinfo@gmail.com
CONSULTATION_FROM_EMAIL=

# Dashboard business /admin?secret=...
ADMIN_SECRET=
