# GPT-4o Vision è il provider principale per l'analisi documentale pubblica.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Gemini è facoltativo e viene usato solo come fallback controllato.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_FALLBACK_MODELS=gemini-2.0-flash
GEMINI_VISION_USE_SCHEMA=0

# Token richiesto per visualizzare /admin/evaluation?token=...
ADMIN_EVALUATION_TOKEN=
